# Copie para .env e ajuste antes de subir no NAS:
#   cp .env.example .env
#   docker compose -f docker-compose.nas.yml up -d --build

# Obrigatorio. Gere com:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# IP/hostname do NAS, separados por virgula.
DJANGO_ALLOWED_HOSTS=192.168.1.10,nas.local

# Necessario se acessar por https ou porta diferente (inclua o esquema).
# Ex: https://financeiro.meudominio.com,http://192.168.1.10:8231
DJANGO_CSRF_TRUSTED_ORIGINS=http://192.168.1.10:8231

# Opcional
GUNICORN_WORKERS=2
